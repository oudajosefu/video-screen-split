{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build:display-app",
      "type": "shell",
      "command": "npm",
      "args": ["--workspace=display-app", "run", "build"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
